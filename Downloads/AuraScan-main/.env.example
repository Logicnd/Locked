# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  AURASCAN ENVIRONMENT - Copy to .env.local and add your API keys         ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ═══════════════════════════════════════════════════════════════════════════
# ✅ AUTO-CONFIGURED (No changes needed)
# ═══════════════════════════════════════════════════════════════════════════
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AuraScan
NODE_ENV=development

# ═══════════════════════════════════════════════════════════════════════════
# 🔑 REQUIRED API KEYS
# ═══════════════════════════════════════════════════════════════════════════

# Supabase (Database & Auth)
# Get from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OpenAI (Ethics Analysis)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Stripe (Payments)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Stripe Price IDs
# Get from: https://dashboard.stripe.com/products → Click product → Copy Price ID
STRIPE_PRICE_ID_MONTHLY=
STRIPE_PRICE_ID_YEARLY=

# ═══════════════════════════════════════════════════════════════════════════
# 🔧 OPTIONAL (Add these later if you need them)
# ═══════════════════════════════════════════════════════════════════════════

# Anthropic Claude - https://console.anthropic.com/
#ANTHROPIC_API_KEY=

# Perspective API - https://perspectiveapi.com/
#PERSPECTIVE_API_KEY=

# Push Notifications - Run: npx web-push generate-vapid-keys
#NEXT_PUBLIC_VAPID_PUBLIC_KEY=
#VAPID_PRIVATE_KEY=

# Email (Resend) - https://resend.com/api-keys
#RESEND_API_KEY=

# Rate Limiting (Upstash) - https://console.upstash.com/
#UPSTASH_REDIS_REST_URL=
#UPSTASH_REDIS_REST_TOKEN=

# Encryption - Run: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#ENCRYPTION_KEY=

# Scan Secret (Keyed scan output) - reuse ENCRYPTION_KEY or set a dedicated key
#SCAN_SECRET=
