# ============================================
# LOCKED SITE PUZZLE - Environment Variables
# ============================================

# Server Configuration
PORT=3000
NODE_ENV=production

# Session Secret (Generate a strong random string for production)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=your-super-secret-session-key-change-this-in-production

# Leaderboard Reset Key (Required to reset leaderboard via API)
# Keep this secure - anyone with this key can reset all leaderboard data!
LEADERBOARD_RESET_KEY=your-secure-reset-key-change-this

# Frontend WebSocket URL (Optional - for multiplayer racing)
# If not set, will default to current host with ws:// protocol
# REACT_APP_WS_URL=wss://your-vercel-app.vercel.app

# ============================================
# HOW TO USE:
# ============================================
# 1. Change all the placeholder values above
# 2. For Vercel: Add these in Project Settings > Environment Variables
# 3. For local: Rename this file to .env (remove .example if you copied it)
# 4. NEVER commit .env to git! (It should be in .gitignore)
#
# TO GENERATE SECRETS:
# - Session Secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# - Reset Key: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
